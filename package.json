  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "intelligence/*",
    "extensions/*",
    "analytics/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
