{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "dev:storefront": "npm run dev -w @dokanx/storefront-web",
    "dev:merchant": "npm run dev -w @dokanx/merchant-dashboard",
    "dev:admin": "npm run dev -w @dokanx/admin-panel",
    "dev:developer": "npm run dev -w @dokanx/developer-portal",
    "dev:mobile": "npm run dev -w @dokanx/mobile-app",
    "load:test": "node -r module-alias/register src/load/wallet.loadtest.js",
    "start": "cross-env NODE_ENV=production node src/server.js",
    "test": "cross-env NODE_ENV=test jest --config jest.core.config.js --runInBand --detectOpenHandles",
    "test:unit": "cross-env NODE_ENV=test TEST_SKIP_DB=true jest --config jest.core.config.js --runInBand --detectOpenHandles",
    "test:core": "cross-env NODE_ENV=test jest --config jest.core.config.js --runInBand --detectOpenHandles",
    "test:db": "cross-env NODE_ENV=test TEST_USE_DB=true TEST_DB_OPTIONAL=false jest --config jest.core.config.js --runInBand --detectOpenHandles",
    "test:legacy-payout": "cross-env NODE_ENV=test jest --config jest.legacy-payout.unit.config.js --runInBand --detectOpenHandles",
    "test:legacy-payout:int": "cross-env NODE_ENV=test jest --config jest.legacy-payout.int.config.js --runInBand --detectOpenHandles --forceExit",
    "test:all": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:validation": "cross-env NODE_ENV=test jest --config jest.validation.config.js --runInBand",
    "indexes:sync": "node src/scripts/syncPlatformIndexes.js"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.69.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "eventemitter2": "^6.4.9",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "minimatch": "^9.0.5",
    "module-alias": "^2.3.4",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redlock": "^5.0.0-beta.2",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "babel-jest": "30.2.0",
    "cross-env": "^10.1.0",
    "jest": "30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.13",
    "supertest": "^7.2.2"
  }
}
