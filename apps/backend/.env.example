# ===========================
# CLOUDFLARE R2 CONFIGURATION
# ===========================

R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=dokanx-media

# CDN Base URL (use your custom domain or Cloudflare-provided URL)
CDN_BASE_URL=https://cdn.yourdomain.com
# OR use Cloudflare's default:
# CDN_BASE_URL=https://pub-YOUR_ID.r2.dev

# ===========================
# MEDIA SYSTEM SETTINGS
# ===========================

# Maximum file size in bytes (default: 5MB = 5242880)
MAX_FILE_SIZE=5242880

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Image quality presets
IMAGE_QUALITY_PRODUCT=80
IMAGE_QUALITY_BANNER=85
IMAGE_QUALITY_LOGO=90
IMAGE_QUALITY_RIDER_PROOF=75

# ===========================
# EXISTING CONFIGURATION
# ===========================

NODE_ENV=development
PORT=3000
MONGO_URL=mongodb://localhost:27017/dokanx
JWT_SECRET=your_jwt_secret_key
