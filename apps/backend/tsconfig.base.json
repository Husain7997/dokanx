{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@dokanx/ui": ["packages/ui/src/index.ts"],
      "@dokanx/api-client": ["packages/api-client/src/index.ts"],
      "@dokanx/auth": ["packages/auth/src/index.ts"],
      "@dokanx/hooks": ["packages/hooks/src/index.ts"],
      "@dokanx/types": ["packages/types/src/index.ts"],
      "@dokanx/utils": ["packages/utils/src/index.ts"],
      "@dokanx/config/*": ["packages/config/*"]
    }
  }
}
