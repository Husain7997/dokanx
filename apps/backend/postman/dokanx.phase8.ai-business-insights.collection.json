  "item": [
    {
      "name": "Get Business Insights (7 days)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/insights/business?days=7&limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["insights", "business"],
          "query": [
            { "key": "days", "value": "7" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
