{
  "name": "@dokanx/mobile-app",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "npx react-native start",
    "android": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\install-android.ps1 -App customer",
    "bundle:android:debug": "powershell -ExecutionPolicy Bypass -Command \"$assets='android/app/src/main/assets'; if (-not (Test-Path $assets)) { New-Item -ItemType Directory -Path $assets | Out-Null }; npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/\"",
    "build:android:debug": "cmd /c npm.cmd run bundle:android:debug && cd android && gradlew.bat assembleDebug",
    "build:android:release": "cd android && gradlew.bat assembleRelease",
    "bundle:android:release": "cd android && gradlew.bat bundleRelease",
    "ios": "npx react-native run-ios",
    "test": "jest"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.26",
    "@sentry/react-native": "^6.16.0",
    "micromatch": "^4.0.8",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.84.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.25.0",
    "react-native-keychain": "^10.0.0",
    "react-native-maps": "^1.18.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.24.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.0",
    "@react-native-community/cli-platform-android": "^20.1.0",
    "@react-native-community/cli-platform-ios": "^20.1.0",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/gradle-plugin": "^0.84.1",
    "@react-native/metro-config": "^0.84.1",
    "@react-native/typescript-config": "^0.84.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.2.3",
    "typescript": "^5.8.2"
  }
}